---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projetos = await getCollection('projetos');
  return projetos.map((projeto) => ({
    params: { slug: projeto.id },
    props: { projeto },
  }));
}

const { projeto } = Astro.props;
const { Content } = await render(projeto);

const dataFormatada = projeto.data.data.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
});
---

<Layout title={projeto.data.titulo} description={projeto.data.descricao}>
  <article class="max-w-3xl mx-auto px-6 py-16">

    <!-- Back link -->
    <a
      href="/#projetos"
      class="inline-flex items-center gap-2 text-sm mb-12 transition-colors"
      style="color: var(--color-text-muted);"
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-text-muted)'"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Voltar
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-mono" style="color: var(--color-text-muted);">{dataFormatada}</span>
        {projeto.data.destaque && (
          <span
            class="text-xs font-mono px-2 py-0.5 rounded-full border"
            style="color: var(--color-accent); border-color: color-mix(in srgb, var(--color-accent) 30%, transparent); background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);"
          >
            destaque
          </span>
        )}
      </div>

      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-4" style="color: var(--color-text-primary);">
        {projeto.data.titulo}
      </h1>

      <p class="text-base leading-relaxed mb-6" style="color: var(--color-text-secondary);">
        {projeto.data.descricao}
      </p>

      <!-- Stack -->
      <div class="flex flex-wrap gap-2 mb-6">
        {projeto.data.stack.map((tech) => (
          <span
            class="text-xs font-mono px-2 py-1 rounded"
            style="color: var(--color-text-muted); background-color: var(--color-surface);"
          >
            {tech}
          </span>
        ))}
      </div>

      <!-- Repo link -->
      {projeto.data.repositorio && (
        <a
          href={projeto.data.repositorio}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
          style="color: var(--color-accent);"
          onmouseover="this.style.color='var(--color-accent-hover)'"
          onmouseout="this.style.color='var(--color-accent)'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          Ver repositório
        </a>
      )}
    </header>

    <!-- Divider -->
    <hr class="mb-10" style="border-color: var(--color-border);" />

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }

  .prose :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .prose :global(p) {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 0.25rem;
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background-color: var(--color-surface-2);
    color: var(--color-accent);
  }

  .prose :global(pre) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
